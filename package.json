{
  "name": "py01-restaurantes",
  "version": "1.0.0",
  "private": true,
  "description": "Monorepo del proyecto PY01 Restaurantes",
  "workspaces": [
    "services/api",
    "services/search"
  ],
  "scripts": {
    "dev:api": "npm run dev --workspace services/api",
    "dev:search": "npm run dev --workspace services/search",
    "test": "npm run test --workspace services/api && npm run test --workspace services/search",
    "test:integration": "docker compose -f docker-compose.test.yml up --build --abort-on-container-exit",
    "lint": "npm run lint --workspace services/api && npm run lint --workspace services/search",
    "seed:postgres": "DB_ENGINE=postgres node infra/scripts/seed-data.js",
    "seed:mongodb": "DB_ENGINE=mongodb node infra/scripts/seed-data.js",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down"
  },
  "engines": {
    "node": ">=22"
  }
}
