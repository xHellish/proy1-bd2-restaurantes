# ===== Global Configuration =====
NODE_ENV=development
JWT_SECRET=your_jwt_secret_change_in_prod
DB_ENGINE=postgres

# ===== API Service Configuration =====
API_PORT=3000
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/restaurantes
MONGO_URI=mongodb://mongo1:27017,mongo2:27018,mongo3:27019/restaurantes?replicaSet=rs0
REDIS_URL=redis://redis:6379
ELASTIC_URL=http://elasticsearch:9200
SEARCH_SERVICE_URL=http://search:4000

# ===== Search Service Configuration =====
SEARCH_PORT=4000

# ===== Database Services =====
# PostgreSQL
POSTGRES_DB=restaurantes
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# MongoDB
MONGODB_DATABASE=restaurantes

# Redis
# (No additional config needed, uses default port 6379)

# ===== Elasticsearch =====
# (No additional config needed for dev, security disabled)

# ===== Test Environment (used by CI/CD) =====
# These are automatically set in the GitHub Actions workflow
# but can be used locally with docker-compose.test.yml
#
# DATABASE_URL=postgresql://test_user:test_password@localhost:5432/test_db
# MONGO_URI=mongodb://localhost:27017/test_db
# REDIS_URL=redis://localhost:6379
# ELASTIC_URL=http://localhost:9200
